# Data — large binary/data dirs; metadata tracked via per-dir .gitignore
# (pretrained/ and dataset_store/ each have their own .gitignore for README*/CLAUDE.md)
site_collected/

# Outputs & runs
runs/
outputs/
*.wandb/
wandb/

# Python
__pycache__/
*.pyc
*.pyo
*.egg-info/
.venv/
.venv-export/
.venv-notebook/
.venv-yolox-official/
venv/
.env

# IDE
.vscode/
.idea/
*.swp
*.swo

# OS
.DS_Store
.._MACOSX/

# DVC
.dvc/cache/
.dvc/tmp/

# Services
services/*/logs/
services/*/.env

# Tests
.pytest_cache/
.coverage
htmlcov/

# Build
dist/
build/

# Third-party MCP servers under .claude/ — track source, ignore venv/cache
.claude/roboflow-mcp/venv/
.claude/roboflow-mcp/__pycache__/

# Claude Code runtime state
.claude/scheduled_tasks.lock
.claude/plugins/*/.claude-plugin/marketplace.json

