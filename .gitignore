# Python
__pycache__/
.pytest_cache/
*.py[cod]
*.egg-info/
dist/
build/
*.egg

# Virtual environments
.venv/
venv/

# Model files (large binaries — tracked via DVC, not git)
*.pt
*.pth
*.onnx

# Pretrained weights (downloaded, not generated)
pretrained/*
!pretrained/README.md
!pretrained/*/
pretrained/*/*
!pretrained/*/README.md

# Training runs (experiment outputs, regenerated)
runs/*
!runs/README.md
# Per-feature runs (features/<name>/runs/ from training/pipeline tests)
features/*/runs/
# Per-feature samples + inference predictions (large binaries / regenerated)
features/*/samples/
!features/*/samples/.gitkeep
!features/*/samples/README.md
features/*/predict/
!features/*/predict/.gitkeep
!features/*/predict/README.md
!features/*/predict/QUALITY_REPORT.md
# Test-only features scaffolded by the test suite
features/test_*/

# Released models (versioned via DVC)
releases/*
!releases/README.md
!releases/_template/

# Datasets — ignore data files, keep folder structure via .gitkeep
dataset_store/**
!dataset_store/**/
!dataset_store/**/.gitkeep
!dataset_store/README.md
!dataset_store/DATASET_OVERVIEW.md
!dataset_store/**/DATASET_REPORT.md
!dataset_store/.gitignore
# Raw datasets (large, managed externally)
dataset_store/raw/

# Runtime data (face gallery enrollments, etc.)
data/

# Test outputs (regenerated by test runs)
tests/outputs/
tests/synthetic_fire/

# Weights & Biases logs
wandb/*
!wandb/README.md

# IDE
.idea/
.vscode/
*.swp

# OS
.DS_Store
Thumbs.db

# Environment files (secrets)
.env

# Claude Code
.claude/

# DVC storage
/dvc-storage/

# Lock files
uv.lock

# Service artifacts
services/*/tests/outputs/
services/*/uv.lock
services/sam3/output_*.png
services/sam3/assets/
temp/

# Scripts
scripts/bootstrap

# Misc
dataset_store/note.md
dataset_store/test_*/
app_demo/demo_videos/*
test_foder/
