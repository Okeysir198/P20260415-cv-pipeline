# Dataset config — {{FEATURE_NAME}}
dataset_name: "{{DATASET_NAME}}"
path: "../../../dataset_store/training_ready/{{DATASET_NAME}}"
train: "train/images"
val: "val/images"
test: "test/images"

names:
{{NAMES_YAML_BLOCK}}      # e.g.  0: person
                          #       1: head_with_helmet
                          #       2: head_without_helmet
num_classes: {{NUM_CLASSES}}
input_size: [640, 640]

# Normalization (ImageNet defaults; re-compute via core/p05_data/compute_normalization.py if needed)
mean: [0.485, 0.456, 0.406]
std: [0.229, 0.224, 0.225]

# SAM3-friendly text prompts — required by core/p01_auto_annotate when re-labeling.
# Be specific enough that SAM3 can find the object; avoid overly broad phrases.
text_prompts:
{{TEXT_PROMPTS_YAML_BLOCK}}
  # Example:
  #   person: "a person standing, walking, or working at a construction site"
  #   head_with_helmet: "a person's head wearing a hard hat or safety helmet"
  #   head_without_helmet: "a person's bare uncovered head, no helmet"
